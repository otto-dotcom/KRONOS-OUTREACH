          },
          {
            "node": "WhatsApp - Send Message",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Brevo - Send Email": {
      "main": [
        [
          {
            "node": "Airtable - Update Status",
            "type": "main",
