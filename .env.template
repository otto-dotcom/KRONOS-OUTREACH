# n8n Configuration
N8N_HOST=n8n.kronosautomations.com
N8N_USER=admin
N8N_PASSWORD=changeme

# --- AI / LLM (OpenRouter — OpenAI-compatible API) ---
# Create an "OpenAI" credential in n8n with:
#   API Key: your OpenRouter key (sk-or-v1-...)
#   Base URL: https://openrouter.ai/api/v1
OPENROUTER_API_KEY=sk-or-v1-your_key_here

# --- Twilio (WhatsApp / SMS) ---
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX

# --- Email Sending (Brevo / SendGrid) ---
BREVO_API_KEY=your_brevo_api_key
SENDER_EMAIL=your-email@yourdomain.com

# --- Test Targets (for test_agents.py) ---
TEST_TARGET_EMAIL=your-test@example.com
TEST_TARGET_WHATSAPP=whatsapp:+1XXXXXXXXXX
