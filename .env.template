# ========================
# KRONOS-OUTREACH ENV
# ========================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.

# --- n8n API ---
N8N_API_KEY=your_api_key_here
N8N_BASE_URL=https://your-n8n-instance.app

# --- n8n Docker (for docker-compose.yml) ---
N8N_HOST=n8n.yourdomain.com
N8N_USER=admin
N8N_PASSWORD=your_secure_password_here

# --- AI / LLM ---
OLLAMA_MODEL=llama3.2
OLLAMA_HOST=http://localhost:11434

# --- Twilio (WhatsApp / SMS) ---
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_NUMBER=whatsapp:+1XXXXXXXXXX

# --- SendGrid (Email) ---
SENDGRID_API_KEY=SG.your_sendgrid_api_key
SENDGRID_FROM_EMAIL=your-email@yourdomain.com

# --- Test Targets (for test_agents.py) ---
TEST_TARGET_EMAIL=your-test@example.com
TEST_TARGET_WHATSAPP=whatsapp:+1XXXXXXXXXX
