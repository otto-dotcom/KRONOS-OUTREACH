              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ sender: { name: \"KRONOS Error\", email: \"otto@kronosbusiness.com\" }, to: [{ email: \"consulting@kronosautomations.com\" }], subject: \"KRONOS Outreach Error - \" + $json.execution.id, htmlContent: \"<p>Error in: <strong>\" + $json.execution.lastNodeExecuted + \"</strong></p><p>\" + ($json.execution.error && $json.execution.error.message) + \"</p>\" }) }}",
        "options": {}
      },
      "credentials": {
        "httpHeaderAuth": {
          "id": "YOUR_BREVO_CREDENTIAL_ID",
          "name": "Brevo API Key"
        }
      }
    }
