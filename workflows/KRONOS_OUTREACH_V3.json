        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "id": "={{ $('Parse WA Output').item.json.id }}",
            "sms status": "sent",
            "SMS": "={{ $('Parse WA Output').item.json.waMessage }}"
          },
          "matchingColumns": [
            "id"
          ],
          "schema": [
            {
              "id": "id",
              "displayName": "id",
              "required": false,
              "defaultMatch": true,
              "display": true,
              "type": "string",
              "canBeUsedToMatch": true
            }
          ]
        },
        "options": {}
      },
      "credentials": {
        "airtableTokenApi": {
          "id": "YOUR_AIRTABLE_CREDENTIAL_ID",
          "name": "Airtable Personal Access Token account"
        }
      }
    },
